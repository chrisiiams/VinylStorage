<Window x:Class="VinylStorage.Add"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add Vinyl" Height="420" Width="320">
    <Grid>
        <Label Content="Add Vinyl" HorizontalAlignment="Center" Margin="0,20,0,0" VerticalAlignment="Top" FontSize="28" FontWeight="Bold"/>

        <Label Content="Artist"      HorizontalAlignment="Left" Margin="30,90,0,0"  VerticalAlignment="Top"/>
        <Label Content="Album Title" HorizontalAlignment="Left" Margin="30,130,0,0" VerticalAlignment="Top"/>
        <Label Content="Year"        HorizontalAlignment="Left" Margin="30,170,0,0" VerticalAlignment="Top"/>
        <Label Content="Genre"       HorizontalAlignment="Left" Margin="30,210,0,0" VerticalAlignment="Top"/>
        <Label Content="Condition"   HorizontalAlignment="Left" Margin="30,250,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="inputArtist"     HorizontalAlignment="Left" Margin="140,93,0,0"  VerticalAlignment="Top" Width="140"/>
        <TextBox x:Name="inputAlbumTitle" HorizontalAlignment="Left" Margin="140,133,0,0" VerticalAlignment="Top" Width="140"/>
        <TextBox x:Name="inputYear"       HorizontalAlignment="Left" Margin="140,173,0,0" VerticalAlignment="Top" Width="140"/>
        <TextBox x:Name="inputGenre"      HorizontalAlignment="Left" Margin="140,213,0,0" VerticalAlignment="Top" Width="140"/>

        <ComboBox x:Name="inputCondition" HorizontalAlignment="Left" Margin="140,253,0,0" VerticalAlignment="Top" Width="140">
            <ComboBoxItem Content="Mint"/>
            <ComboBoxItem Content="Near Mint"/>
            <ComboBoxItem Content="Very Good"/>
            <ComboBoxItem Content="Good"/>
            <ComboBoxItem Content="Poor"/>
        </ComboBox>

        <Button x:Name="AddButton" Content="ADD" HorizontalAlignment="Center" Margin="0,310,0,0"
                VerticalAlignment="Top" Height="50" Width="220" FontSize="20" Click="AddButton_Click"/>
    </Grid>
</Window>
