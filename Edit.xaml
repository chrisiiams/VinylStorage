<Window x:Class="VinylStorage.Edit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edit Vinyl" Height="540" Width="520">
    <Grid>
        <!-- Left: cover art -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="20,20,0,0" Width="200" Height="200"
                BorderBrush="#CCCCCC" BorderThickness="1" Background="#F0F0F0">
            <Grid>
                <TextBlock x:Name="coverPlaceholder" Text="Loading ..."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#888888" TextWrapping="Wrap" TextAlignment="Center" Margin="10"/>
                <Image x:Name="coverImage" Stretch="UniformToFill" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Title + refresh below cover -->
        <Label Content="Edit Vinyl" HorizontalAlignment="Left" Margin="20,230,0,0"
               VerticalAlignment="Top" FontSize="20" FontWeight="Bold"/>
        <Button x:Name="RefreshCover" Content="↻ Refresh Cover" HorizontalAlignment="Left"
                Margin="20,268,0,0" VerticalAlignment="Top" Height="28" Width="200"
                Click="RefreshCover_Click"/>

        <!-- Right: form fields -->
        <Label Content="Interpret*in"      HorizontalAlignment="Left" Margin="250,20,0,0"  VerticalAlignment="Top"/>
        <Label Content="Album Titel" HorizontalAlignment="Left" Margin="250,65,0,0"  VerticalAlignment="Top"/>
        <Label Content="Jahr"        HorizontalAlignment="Left" Margin="250,110,0,0" VerticalAlignment="Top"/>
        <Label Content="Genre"       HorizontalAlignment="Left" Margin="250,155,0,0" VerticalAlignment="Top"/>
        <Label Content="Zustand"   HorizontalAlignment="Left" Margin="250,200,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="inputArtist"     HorizontalAlignment="Left" Margin="250,42,0,0"  VerticalAlignment="Top" Width="230"/>
        <TextBox x:Name="inputAlbumTitle" HorizontalAlignment="Left" Margin="250,87,0,0"  VerticalAlignment="Top" Width="230"/>
        <TextBox x:Name="inputYear"       HorizontalAlignment="Left" Margin="250,132,0,0" VerticalAlignment="Top" Width="230"/>
        <TextBox x:Name="inputGenre"      HorizontalAlignment="Left" Margin="250,177,0,0" VerticalAlignment="Top" Width="230"/>

        <ComboBox x:Name="inputCondition" HorizontalAlignment="Left" Margin="250,222,0,0" VerticalAlignment="Top" Width="230">
            <ComboBoxItem Content="Mint"/>
            <ComboBoxItem Content="Near Mint"/>
            <ComboBoxItem Content="Very Good"/>
            <ComboBoxItem Content="Good"/>
            <ComboBoxItem Content="Poor"/>
        </ComboBox>

        <!-- Save button -->
        <Button x:Name="Save" Content="SAVE" HorizontalAlignment="Center" Margin="0,460,0,0"
                VerticalAlignment="Top" Height="44" Width="460" FontSize="18" FontWeight="Bold"
                Click="Save_Click"/>
    </Grid>
</Window>
